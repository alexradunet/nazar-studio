# Local Pi agent runtime/auth/session state
.pi/agent/**
.pi/npm/node_modules/**
.pi/npm/package.json
.pi/npm/package-lock.json
.pi/git/github.com/**

# Workspace/package npm dependencies are reproducible from package manifests
node_modules/**
packages/*/node_modules/**

# Private/generated Pi memory (external vault preferred; repo-local fallback is local-only)
/memory/

# Local review/handoff artifacts
handoff/
publish-audit/
audit/

# WhatsApp gateway linked-device session (secrets — never commit)
.wwebjs_auth/
**/whatsapp-auth/
.nazar-data/
