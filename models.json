{
  "providers": {
    "llamafile": {
      "baseUrl": "http://127.0.0.1:8082/v1",
      "api": "openai-completions",
      "apiKey": "$LLAMA_LOCAL_KEY",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false,
        "supportsUsageInStreaming": false,
        "supportsStrictMode": false,
        "supportsStore": false,
        "maxTokensField": "max_tokens",
        "thinkingFormat": "qwen-chat-template"
      },
      "models": [
        {
          "id": "qwen3-14b-q4",
          "reasoning": false,
          "contextWindow": 32768,
          "maxTokens": 8192,
          "input": ["text"],
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "qwen3.6-35b-a3b-apex-i-compact",
          "reasoning": false,
          "contextWindow": 32768,
          "maxTokens": 8192,
          "input": ["text"],
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    }
  },
  "_notes": "Canonical local runtime is the pi/extensions/local-llm.ts extension: Mozilla llamafile serves the OpenAI-compatible local LLM endpoint on 127.0.0.1:8082, and Mozilla whisperfile handles local audio transcription. No native build/systemd fallback is canonical. The default model can be selected with NAZAR_MODEL_* / NAZAR_PRIVATE_MODEL in .env; keep qwen3-14b-q4 as the known-small fallback."
}
