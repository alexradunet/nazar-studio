# Copy this file to .env and fill only what you need.

########################################
# Balaur runtime
########################################

# Provider/model selection
BALAUR_MODEL=synthetic/syn:large:text

# Optional custom runtime location
BALAUR_DATA_DIR=~/.balaur-data

# Optional built-in REST API host/port
BALAUR_API_HOST=127.0.0.1
BALAUR_API_PORT=8787

# Optional explicit dotenv path (takes precedence)
# BALAUR_ENV_FILE=.env.local

########################################
# API keys
########################################

# Synthetic (default provider)
SYNTHETIC_API_KEY=
BALAUR_SYNTHETIC_API_KEY=

# OpenAI-style providers
OPENAI_API_KEY=
BALAUR_OPENAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
BALAUR_OPENROUTER_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
BALAUR_ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
BALAUR_GEMINI_API_KEY=

# Groq
GROQ_API_KEY=
BALAUR_GROQ_API_KEY=

# Mistral AI
MISTRAL_API_KEY=
BALAUR_MISTRAL_API_KEY=

# xAI
XAI_API_KEY=
BALAUR_XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
BALAUR_DEEPSEEK_API_KEY=

# Cohere
COHERE_API_KEY=
BALAUR_COHERE_API_KEY=

# Together AI
TOGETHER_API_KEY=
BALAUR_TOGETHER_AI_API_KEY=

# Per-provider key formats that require additional env vars live on their SDK docs.
# Azure OpenAI example envs:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
BALAUR_AZURE_OPENAI_API_KEY=
