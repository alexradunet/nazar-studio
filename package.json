{
  "name": "balaur",
  "version": "0.1.0",
  "description": "Balaur — a sovereign, local-first personal agent with a Bun/Ink interface, Johnny Decimal Markdown vault, skills, and local-first conversation runtime.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "homepage": "https://balaur.studio",
  "keywords": [
    "balaur",
    "agent-runtime",
    "agent",
    "local-first",
    "vault",
    "skills",
    "ink",
    "bun",
    "sovereign"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "balaur": "./src/main.tsx"
  },
  "scripts": {
    "test": "bun test lib/runtime lib/tui lib/avatar lib/design lib/vault.test.ts lib/env.test.ts",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "balaur": "bun src/main.tsx",
    "api": "bun src/api.ts",
    "build:balaur:bun": "bun build src/main.tsx --compile --outfile dist/balaur",
    "reindex": "bun src/reindex.ts",
    "prepublishOnly": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-ai": "^0.78.1",
    "ink": "^7.0.5",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "bun-types": "1.3.14",
    "typescript": "^5.6.0"
  },
  "files": [
    "lib",
    "skills",
    "assets",
    "models.json",
    ".env.example",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "NOTICE",
    "src"
  ],
  "trustedDependencies": []
}
